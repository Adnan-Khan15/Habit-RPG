# ═══════════════════════════════════════════════════════════════════════════════
# Supabase Edge Function Secrets
# Set these in the Supabase Dashboard:
#   Project Settings → Edge Functions → Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# Stripe API key (secret, NOT publishable). Starts with sk_live_ or sk_test_.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret. Created in Stripe Dashboard:
#   Developers → Webhooks → Add endpoint → https://<project>.supabase.co/functions/v1/stripe-webhook
# Starts with whsec_.
STRIPE_WEBHOOK_SECRET=whsec_...

# Your app's public URL (used for Stripe success/cancel redirects).
# Must match the domain you set in Stripe's redirect_allowlist.
APP_URL=http://localhost:5173

# Supabase project URL — same as VITE_SUPABASE_URL in your .env.local.
SUPABASE_URL=https://nrrphpzrtwbxahnswjlp.supabase.co

# Service Role key (secret, NOT anon key). Found in:
#   Project Settings → API → service_role key
# ⚠ NEVER expose this client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
